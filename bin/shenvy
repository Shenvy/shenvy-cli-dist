#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*) exe_ext=.exe ;;
    *) exe_ext= ;;
esac

if [ -x "$basedir/shenvy-bin" ]; then
  "$basedir/shenvy-bin" "$@"
else
  # Fallback if binary is not yet downloaded
  node "$basedir/install.js" && "$basedir/shenvy-bin" "$@"
fi
